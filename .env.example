# Harmony AI adapter — copy to .env to override. No paid API key is ever required.
#
# AI_PROVIDER selects how the ONE real AI feature (legislation -> form scaffold) runs:
#   mock      deterministic canned scaffold. Demo-safe default, always works on stage.
#   cli       shells out to the local `claude` CLI — runs through your subscription, no API key.
#   ollama    local model on http://localhost:11434 — on-prem, the data-sovereignty pitch.
#   lmstudio  local model via LM Studio's OpenAI-compatible API on http://localhost:1234/v1.
AI_PROVIDER=mock

# cli mode: path to the claude binary (the shell `claude` is a function, so set the real binary).
CLAUDE_BIN=/Users/vlad3v/.local/bin/claude

# ollama mode (Ilya's machine):
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# lmstudio mode: run `lms server start` and load a model in LM Studio first.
# LMSTUDIO_MODEL can stay "local-model" — LM Studio uses whatever model is loaded.
LMSTUDIO_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
