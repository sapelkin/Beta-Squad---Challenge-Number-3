# Harmony AI adapter — copy to .env to override. No paid API key is ever required.
#
# AI_PROVIDER selects how the ONE real AI feature (legislation -> form scaffold) runs:
#   mock      deterministic canned scaffold. Demo-safe, always works on stage.
#   cli       shells out to the local `claude` CLI — runs through your subscription, no API key.
#   lmstudio  local model via LM Studio's OpenAI-compatible API on http://localhost:1234
#             — fully on-prem, the data-sovereignty pitch. This is the default below.
AI_PROVIDER=lmstudio

# cli mode: path to the claude binary (the shell `claude` is a function, so set the real binary).
CLAUDE_BIN=/Users/vlad3v/.local/bin/claude

# lmstudio mode: in LM Studio, load Llama-3.2-1B-Instruct-4bit, then Developer tab → Start Server.
# Confirm the exact model id the server exposes with:  curl http://localhost:1234/v1/models
LMSTUDIO_URL=http://localhost:1234
LMSTUDIO_MODEL=llama-3.2-1b-instruct
